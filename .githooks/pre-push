#!/usr/bin/env bash
# Pre-push hook: run agentic-code-review via the project's configured LLM.
#
# Enable with:  git config core.hooksPath .githooks
#
# The review is a sensor, not a verdict. A human owns the merge.
# If the LLM is not configured, the script warns and lets the push through.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PYTHON="$REPO_ROOT/backend/.venv/bin/python"
REVIEW_SCRIPT="$REPO_ROOT/scripts/pre-push-review.py"
ZERO="0000000000000000000000000000000000000000"

# --- read ref updates from stdin ------------------------------------------- #

while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip branch deletions.
    if [[ "$local_sha" == "$ZERO" ]]; then
        continue
    fi

    # Compute the diff range.
    if [[ "$remote_sha" == "$ZERO" ]]; then
        # New branch: diff against merge-base with main.
        base_sha=$(git merge-base origin/main "$local_sha" 2>/dev/null || true)
        if [[ -z "$base_sha" ]]; then
            echo "pre-push-review: WARNING - cannot determine merge-base with origin/main."
            echo "  Run 'git fetch origin main' first, or review manually."
            echo "  Skipping AI review for this push."
            continue
        fi
        range="$base_sha..$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    diff_text=$(git diff "$range" --no-color 2>/dev/null || true)
    if [[ -z "$diff_text" ]]; then
        continue
    fi

    # Run the review.
    if [[ ! -f "$PYTHON" ]]; then
        echo "pre-push-review: backend/.venv/bin/python not found -- skipping review"
        echo "  (run: cd backend && python -m venv .venv && .venv/bin/pip install -e .)"
        continue
    fi

    echo ""
    echo "=========================================================="
    echo "  Agentic Code Review  (range: $range)"
    echo "=========================================================="
    echo ""

    echo "$diff_text" | "$PYTHON" "$REVIEW_SCRIPT"

    echo ""
    echo "=========================================================="
    echo ""

    # Ask for confirmation (read from /dev/tty to avoid stdin conflict).
    if [[ -e /dev/tty ]]; then
        read -r -p "Continue with push? [y/N] " answer < /dev/tty
        case "$answer" in
            y|Y|yes|YES)
                echo "Pushing..."
                ;;
            *)
                echo "Push aborted."
                exit 1
                ;;
        esac
    else
        # Non-interactive context (CI, scripted push): fail-closed unless
        # explicitly opted out.  This prevents automated pushes from
        # bypassing review silently.
        if [[ "${PRE_PUSH_REVIEW_SKIP:-}" == "1" ]]; then
            echo "pre-push-review: non-interactive, PRE_PUSH_REVIEW_SKIP=1 set -- proceeding."
        else
            echo "pre-push-review: no tty available and PRE_PUSH_REVIEW_SKIP is not set."
            echo "  Set PRE_PUSH_REVIEW_SKIP=1 to push without interactive review."
            exit 1
        fi
    fi

done

exit 0
