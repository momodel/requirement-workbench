data: {"project_id": "project-b069e87f56", "created_at": "2026-04-24T19:37:52.125860+08:00", "op": "upsert", "items": [{"id": "artifact-d00ad2fd4d", "project_id": "project-b069e87f56", "artifact_type": "page_solution", "title": "需求分析工作台一期页面方案", "summary": "围绕项目列表、三栏工作台（资料索引、聊天区、沉淀区）、交付物预览，给出页面结构、关键组件、状态流转和异常态的完整方案", "status": "generated", "content_format": "html", "storage_path": "/Users/zhaofengli/.codex/worktrees/5182/requirement_nyl/data/projects/project-b069e87f56/artifacts/page_solution/index.html", "preview_url": "/api/projects/project-b069e87f56/artifacts/artifact-d00ad2fd4d/preview", "body": null, "updated_at": "2026-04-24T19:37:40.731476+08:00"}]}

