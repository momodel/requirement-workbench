# =====================================================
# 必填：Claude Agent SDK provider
# =====================================================
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
CLAUDE_MODEL=glm-5

# 如果 `claude` CLI 不在 PATH，需要显式指定绝对路径。
# 安装方式参考：npm i -g @anthropic-ai/claude-code
# CLAUDE_CODE_CLI_PATH=/absolute/path/to/claude

# Claude 运行时可选项
# CLAUDE_MAX_TURNS=6
# CLAUDE_STREAM_TIMEOUT_SECONDS=90
# CLAUDE_STRUCTURED_TIMEOUT_SECONDS=45
# CLAUDE_ARTIFACT_TIMEOUT_SECONDS=180

# =====================================================
# 项目内 RAG（默认本地 Qdrant + FastEmbed，开箱即用）
# =====================================================
# Qdrant 本地数据目录，默认 ../data/qdrant
# REQUIREMENT_WORKBENCH_QDRANT_PATH=../data/qdrant

# 也可以接远程 Qdrant
# REQUIREMENT_WORKBENCH_QDRANT_URL=http://127.0.0.1:6333

# Evidence / embedding / reranker 默认就够用，需要换才填
# REQUIREMENT_WORKBENCH_EVIDENCE_BACKEND=qdrant_llamaindex
# REQUIREMENT_WORKBENCH_EMBEDDER_BACKEND=fastembed
# REQUIREMENT_WORKBENCH_EMBEDDER_MODEL=BAAI/bge-small-zh-v1.5
# REQUIREMENT_WORKBENCH_RERANKER_MODEL=
# REQUIREMENT_WORKBENCH_EVIDENCE_QUERY_TIMEOUT_SECONDS=15
# REQUIREMENT_WORKBENCH_EVIDENCE_RECALL_TOP_K=20
# REQUIREMENT_WORKBENCH_EVIDENCE_TOP_K=6
# REQUIREMENT_WORKBENCH_CHUNK_SIZE=500
# REQUIREMENT_WORKBENCH_CHUNK_OVERLAP=120

# =====================================================
# 音频 ASR + 七牛主链路（可选，仅音频 source 上传需要）
# =====================================================
# REQUIREMENT_WORKBENCH_QINIU_ACCESS_KEY=your-qiniu-access-key
# REQUIREMENT_WORKBENCH_QINIU_SECRET_KEY=your-qiniu-secret-key
# REQUIREMENT_WORKBENCH_QINIU_BUCKET=your-qiniu-bucket
# REQUIREMENT_WORKBENCH_QINIU_DOMAIN=https://your-public-qiniu-domain
# REQUIREMENT_WORKBENCH_QINIU_KEY_PREFIX=audio
# REQUIREMENT_WORKBENCH_ALIYUN_AK_ID=your-aliyun-access-key-id
# REQUIREMENT_WORKBENCH_ALIYUN_AK_SECRET=your-aliyun-access-key-secret
# REQUIREMENT_WORKBENCH_ALIYUN_APP_KEY=your-aliyun-app-key
# REQUIREMENT_WORKBENCH_ALIYUN_FILETRANS_REGION=cn-shanghai
# REQUIREMENT_WORKBENCH_AUDIO_TRANSCRIPTION_BACKEND=aliyun_filetrans
# REQUIREMENT_WORKBENCH_AUDIO_TRANSCRIPTION_TIMEOUT_SECONDS=300
# REQUIREMENT_WORKBENCH_AUDIO_TRANSCRIPTION_POLL_INTERVAL_SECONDS=2

# =====================================================
# 可选：图像生成 provider（apimart）
# 不填的话 chat 内的图像生成调用会直接报 ProviderIssue
# =====================================================
# APIMART_API_KEY=
# APIMART_BASE_URL=
# APIMART_IMAGE_MODEL=

# 上传到 chat 的图片回拼 URL 使用的对外 base，默认 http://127.0.0.1:8001
# 如果后端不是起在 8001，或前端跨机访问，需要改成可访问的地址
# PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# =====================================================
# 可选：覆盖数据目录
# =====================================================
# REQUIREMENT_WORKBENCH_DATA_DIR=/absolute/path/to/data
# REQUIREMENT_WORKBENCH_SQLITE_DIR=/absolute/path/to/data/sqlite
# REQUIREMENT_WORKBENCH_PROJECTS_DIR=/absolute/path/to/data/projects
