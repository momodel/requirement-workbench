# Claude / Anthropic provider
ANTHROPIC_API_KEY=your-key-here
ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
CLAUDE_MODEL=glm-5

# Optional overrides
# CLAUDE_CODE_CLI_PATH=/absolute/path/to/claude
# CLAUDE_MAX_TURNS=6
# CLAUDE_ARTIFACT_TIMEOUT_SECONDS=180

# Project-local RAG defaults
# REQUIREMENT_WORKBENCH_QDRANT_PATH=../data/qdrant
# REQUIREMENT_WORKBENCH_EVIDENCE_BACKEND=qdrant_llamaindex
# REQUIREMENT_WORKBENCH_EMBEDDER_BACKEND=fastembed
# REQUIREMENT_WORKBENCH_EVIDENCE_QUERY_TIMEOUT_SECONDS=15

# Audio ASR + Qiniu mainline (optional, only required for audio source uploads)
# REQUIREMENT_WORKBENCH_QINIU_ACCESS_KEY=your-qiniu-access-key
# REQUIREMENT_WORKBENCH_QINIU_SECRET_KEY=your-qiniu-secret-key
# REQUIREMENT_WORKBENCH_QINIU_BUCKET=your-qiniu-bucket
# REQUIREMENT_WORKBENCH_QINIU_DOMAIN=https://your-public-qiniu-domain
# REQUIREMENT_WORKBENCH_QINIU_KEY_PREFIX=audio
# REQUIREMENT_WORKBENCH_ALIYUN_AK_ID=your-aliyun-access-key-id
# REQUIREMENT_WORKBENCH_ALIYUN_AK_SECRET=your-aliyun-access-key-secret
# REQUIREMENT_WORKBENCH_ALIYUN_APP_KEY=your-aliyun-app-key
# REQUIREMENT_WORKBENCH_ALIYUN_FILETRANS_REGION=cn-shanghai
# REQUIREMENT_WORKBENCH_AUDIO_TRANSCRIPTION_BACKEND=aliyun_filetrans
# REQUIREMENT_WORKBENCH_AUDIO_TRANSCRIPTION_TIMEOUT_SECONDS=300
# REQUIREMENT_WORKBENCH_AUDIO_TRANSCRIPTION_POLL_INTERVAL_SECONDS=2
